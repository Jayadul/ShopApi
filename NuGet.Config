<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <fallbackPackageFolders>
    <!--
      Intentionally empty.
      Windows dev machines bake 'C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages'
      into obj/project.assets.json. Docker runs on Linux and that path does not exist,
      causing MSB4018 / PackagingException at publish time.
      Declaring an empty fallbackPackageFolders here overrides whatever is cached in
      project.assets.json and lets 'dotnet restore - -force' produce a clean Linux-compatible result.
    -->
  </fallbackPackageFolders>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
