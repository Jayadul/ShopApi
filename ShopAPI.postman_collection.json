                  "pm.test('Items is array', () => pm.expect(json.data.items).to.be.an('array'));",
                  "// Auto-save first product id for use in other requests",
                  "if (json.data.items.length > 0) {",
                  "    pm.collectionVariables.set('productId', json.data.items[0].id);",
